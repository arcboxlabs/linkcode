{
  "name": "@linkcode/desktop",
  "version": "0.2.1",
  "private": true,
  "description": "LinkCode desktop application",
  "homepage": "https://linkcode.ai",
  "productName": "LinkCode",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:mock": "electron-vite dev --mode mock",
    "start": "electron-vite preview",
    "build": "electron-vite build",
    "stage:host-runtime": "pnpm -F @linkcode/daemon build && node scripts/stage-sidecar.mts",
    "package": "pnpm run stage:host-runtime && electron-vite build && node scripts/package-app.mts",
    "package:devshell": "pnpm run stage:host-runtime && electron-vite build --mode devshell && node scripts/package-app.mts --devshell",
    "typecheck": "tsc --noEmit",
    "lint": "pnpm --dir ../.. exec eslint --format=sukka apps/desktop"
  },
  "author": "ArcBox Labs <team@arcbox.dev>",
  "dependencies": {
    "@better-auth/electron": "1.7.0-rc.1",
    "@linkcode/common": "workspace:*",
    "@linkcode/daemon": "workspace:*",
    "@linkcode/ipc": "workspace:*",
    "@linkcode/schema": "workspace:*",
    "@linkcode/transport": "workspace:*",
    "@sentry/electron": "^7.14.0",
    "better-auth": "1.7.0-rc.1",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.9",
    "foxts": "^5.6.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@electron/asar": "^4.2.0",
    "@hookform/resolvers": "^5.4.0",
    "@linkcode/ui": "workspace:*",
    "@linkcode/workbench": "workspace:*",
    "@proj-airi/lobe-icons": "catalog:",
    "@sentry/react": "10.60.0",
    "@svgr/core": "catalog:",
    "@svgr/plugin-jsx": "catalog:",
    "@tailwindcss/vite": "catalog:",
    "@types/cross-spawn": "^6.0.6",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "allotment": "^1.20.5",
    "babel-plugin-react-compiler": "catalog:",
    "coss-ui": "workspace:*",
    "cross-spawn": "^7.0.6",
    "electron": "catalog:",
    "electron-builder": "catalog:",
    "electron-vite": "catalog:",
    "foxact": "^0.3.7",
    "lucide-react": "catalog:",
    "motion": "^12.40.0",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-hook-form": "^7.80.0",
    "swr": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "unplugin-icons": "catalog:",
    "vite": "catalog:",
    "zustand": "catalog:"
  }
}
