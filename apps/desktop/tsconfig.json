{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "paths": {
      "@desktop/*": ["./src/*"],
      "@renderer/*": ["./src/renderer/src/*"]
    },
    "types": ["node"]
  },
  "include": [
    "src",
    "scripts",
    "e2e",
    "vite.shared.ts",
    "vite.main.config.ts",
    "vite.preload.config.ts",
    "vite.renderer.config.ts"
  ]
}
