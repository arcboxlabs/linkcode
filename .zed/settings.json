{
  "load_direnv": "direct",
  "format_on_save": "off",
  "languages": {
    "Rust": {
      "format_on_save": "on",
      "formatter": "language_server"
    },
    "JavaScript": {
      "format_on_save": "on",
      "formatter": { "language_server": { "name": "biome" } },
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
        "source.organizeImports.biome": true
      }
    },
    "TypeScript": {
      "format_on_save": "on",
      "formatter": { "language_server": { "name": "biome" } },
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
        "source.organizeImports.biome": true
      }
    },
    "TSX": {
      "format_on_save": "on",
      "formatter": { "language_server": { "name": "biome" } },
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
        "source.organizeImports.biome": true
      }
    },
    "JSON": {
      "format_on_save": "on",
      "formatter": { "language_server": { "name": "biome" } }
    },
    "JSONC": {
      "format_on_save": "on",
      "formatter": { "language_server": { "name": "biome" } }
    }
  },
  "lsp": {
    "rust-analyzer": {
      "initialization_options": {
        // Mirror Rust analyzer checks to Clippy when Rust files are opened.
        "check": {
          "command": "clippy"
        }
      }
    },
    "eslint": {
      "settings": {
        "nodePath": "./node_modules",
        "useFlatConfig": true,
        "workingDirectories": [{ "directory": "." }]
      }
    }
  },
  "file_scan_exclusions": [
    "**/.git",
    "**/.direnv",
    "**/target",
    "**/node_modules",
    "**/dist",
    "**/out",
    "**/build",
    "**/.vite",
    "**/.turbo",
    "**/.next",
    "**/.expo",
    "**/expo-export",
    "**/.wrangler",
    "**/.DS_Store"
  ]
}
