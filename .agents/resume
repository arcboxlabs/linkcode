#!/usr/bin/env bash
set -euo pipefail

export PATH="$HOME/.local/bin:$HOME/.cargo/bin:$PATH"

node_major="$(tr -d '[:space:]' < .nvmrc)"
pnpm_version="$(node -p 'require(`./package.json`).packageManager.split(`@`)[1]')"

if [ "$(node -p 'process.versions.node.split(`.`)[0]')" != "$node_major" ]; then
  echo "Expected Node.js ${node_major}; rerun .agents/setup" >&2
  exit 1
fi

if [ "$(pnpm --version)" != "$pnpm_version" ]; then
  echo "Expected pnpm ${pnpm_version}; rerun .agents/setup" >&2
  exit 1
fi

cargo --version >/dev/null
echo "Orb toolchains are ready; no persistent services require repair"
