# React Native / Expo 的 Metro 打包器对 pnpm 的符号链接式 node_modules 兼容不佳，
# 采用 hoisted 布局让三方依赖平铺，显著降低 mobile 端的解析问题。
node-linker=hoisted

# 自动安装 peer 依赖；关闭严格 peer 报错，避免 RN 生态大量 peer 警告阻塞安装。
auto-install-peers=true
strict-peer-dependencies=false

# 允许常见构建脚本（esbuild / electron / biome 等原生包）执行 postinstall。
enable-pre-post-scripts=true
